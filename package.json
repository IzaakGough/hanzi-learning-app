{
  "name": "hanzi-learning-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @hanzi-learning-app/api\" \"npm run dev --workspace @hanzi-learning-app/web\"",
    "build": "npm run build --workspace @hanzi-learning-app/shared && npm run build --workspace @hanzi-learning-app/api && npm run build --workspace @hanzi-learning-app/web",
    "typecheck": "npm run build --workspace @hanzi-learning-app/shared && npm run typecheck --workspace @hanzi-learning-app/api && npm run typecheck --workspace @hanzi-learning-app/web",
    "lint": "npm run lint --workspace @hanzi-learning-app/shared && npm run lint --workspace @hanzi-learning-app/api && npm run lint --workspace @hanzi-learning-app/web",
    "db:migrate": "npm run db:migrate --workspace @hanzi-learning-app/api",
    "imports:run": "npm run imports:run --workspace @hanzi-learning-app/api",
    "imports:verify": "npm run imports:verify --workspace @hanzi-learning-app/api",
    "admin:verify": "npm run admin:verify --workspace @hanzi-learning-app/api",
    "search:verify": "npm run search:verify --workspace @hanzi-learning-app/api",
    "decomposition:verify": "npm run decomposition:verify --workspace @hanzi-learning-app/api",
    "learning:verify": "npm run learning:verify --workspace @hanzi-learning-app/api",
    "normalize:pleco:characters": "node ./scripts/normalize-pleco-characters.mjs",
    "normalize:pleco:words": "node ./scripts/normalize-pleco-words.mjs",
    "normalize:notion:levels": "node ./scripts/normalize-notion-levels.mjs",
    "normalize:notion:mappings": "node ./scripts/normalize-notion-mappings.mjs",
    "normalize:verify": "npm run build --workspace @hanzi-learning-app/shared && node ./scripts/verify-raw-normalizers.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
